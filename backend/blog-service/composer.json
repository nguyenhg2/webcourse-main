{
    "name": "webcourse/blog-service",
    "description": "Blog and Contact microservice for WebCourse",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "mongodb/laravel-mongodb": "^4.1",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
